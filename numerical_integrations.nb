Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "p2mAmplitude", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"p2mAmplitude", "[", 
   RowBox[{
    RowBox[{"\[CapitalOmega]_", "?", "NumericQ"}], ",", 
    RowBox[{"\[CapitalOmega]p_", "?", "NumericQ"}], ",", 
    RowBox[{"\[Sigma]_", "?", "NumericQ"}], ",", 
    RowBox[{"\[CurlyPhi]0_", "?", "NumericQ"}], ",", 
    RowBox[{"\[CurlyPhi]0p_", "?", "NumericQ"}], ",", 
    RowBox[{"\[Gamma]_", "?", "NumericQ"}], ",", 
    RowBox[{"\[Eta]_", "?", "NumericQ"}]}], "]"}], ":=", 
  RowBox[{
   RowBox[{"p2mAmplitude", "[", 
    RowBox[{
    "\[CapitalOmega]", ",", "\[CapitalOmega]p", ",", "\[Sigma]", ",", 
     "\[CurlyPhi]0", ",", "\[CurlyPhi]0p", ",", "\[Gamma]", ",", "\[Eta]"}], 
    "]"}], "=", 
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      RowBox[{"\[Pi]", " ", "\[Eta]", " ", "\[Gamma]"}], "12"]}], "*", 
    RowBox[{"NIntegrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"NF", "[", "\[Sigma]", "]"}], 
       RowBox[{"\[CapitalOmega]", "^", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "/", "2"}], ")"}]}], "*", 
       RowBox[{"NF", "[", "\[Sigma]", "]"}], "*", 
       RowBox[{"\[CapitalOmega]p", "^", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "/", "2"}], ")"}]}], "*", 
       RowBox[{"Exp", "[", 
        RowBox[{"-", 
         FractionBox[
          RowBox[{
           RowBox[{"Log", "[", 
            RowBox[{"\[Omega]", "/", "\[CapitalOmega]"}], "]"}], "^", "2"}], 
          RowBox[{"2", 
           RowBox[{"\[Sigma]", "^", "2"}]}]]}], "]"}], "*", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], " ", "\[Omega]", " ", "\[CurlyPhi]0"}], "]"}], "*", 
       RowBox[{"Exp", "[", 
        RowBox[{"-", 
         FractionBox[
          RowBox[{
           RowBox[{"Log", "[", 
            RowBox[{"\[Omega]p", "/", "\[CapitalOmega]p"}], "]"}], "^", "2"}], 
          RowBox[{"2", 
           RowBox[{"\[Sigma]", "^", "2"}]}]]}], "]"}], "*", 
       RowBox[{"Exp", "[", 
        RowBox[{"I", " ", "\[Omega]p", " ", "\[CurlyPhi]0p"}], "]"}], "*", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"Sinh", "[", 
            RowBox[{"\[Pi]", "*", 
             RowBox[{"\[Omega]p", "/", "2"}]}], "]"}], "*", 
           RowBox[{"Sinh", "[", 
            RowBox[{"\[Pi]", "*", 
             RowBox[{"\[Omega]", "/", "2"}]}], "]"}]}], "]"}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Cosh", "[", 
           RowBox[{"\[Pi]", "*", 
            RowBox[{"\[Omega]p", "/", "2"}]}], "]"}], "+", 
          RowBox[{"Cosh", "[", 
           RowBox[{"\[Pi]", "*", 
            RowBox[{"\[Omega]", "/", "2"}]}], "]"}]}], ")"}]}], "*", 
